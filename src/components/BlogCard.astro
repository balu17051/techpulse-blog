---
export interface Props {
  title: string;
  description: string;
  date: string;
  tags: string[];
  slug: string;
  image?: string;
}

const { title, description, date, tags, slug, image } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString('de-DE', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group">
  <a href={`/blog/${slug}`} class="block">
    <div class="rounded-xl border border-gray-800 bg-gray-900/50 overflow-hidden hover:border-primary/50 hover:bg-gray-900 transition-all duration-300">
      {image && (
        <div class="aspect-video bg-gradient-to-br from-primary/20 to-accent/20 flex items-center justify-center text-4xl">
          {image}
        </div>
      )}
      <div class="p-5">
        <div class="flex flex-wrap gap-2 mb-3">
          {tags.map((tag) => (
            <span class="px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider rounded bg-gray-800 text-gray-400">
              {tag}
            </span>
          ))}
        </div>
        <h3 class="text-lg font-bold text-white group-hover:text-primary transition-colors mb-2 line-clamp-2">
          {title}
        </h3>
        <p class="text-gray-500 text-sm line-clamp-2 mb-3">{description}</p>
        <time datetime={date} class="text-gray-600 text-xs">{formattedDate}</time>
      </div>
    </div>
  </a>
</article>
