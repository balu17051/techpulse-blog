<header class="border-b border-gray-800 bg-gray-950/80 backdrop-blur-lg sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
    <a href={import.meta.env.BASE_URL} class="flex items-center gap-2 group">
      <span class="text-2xl">🔥</span>
      <span class="text-xl font-extrabold tracking-tight text-white group-hover:text-orange-300 transition-colors">TechPulse Deals</span>
    </a>
    <div class="text-sm font-medium text-gray-400">Amazon-Deals · klar & direkt</div>
  </div>
</header>

<script>
  // Optional: route-slug auf "angebote" normieren, damit nicht mehrere Ansichten existieren
  if (typeof history !== 'undefined') {
    try {
      const p = new URL(location.href).pathname;
      if (p !== '/angebote/' && p !== '/') {
        history.replaceState(null, '', '/angebote/');
      }
    } catch (e) {}
  }
</script>
