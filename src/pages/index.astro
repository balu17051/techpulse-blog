---
import BaseLayout from '../layouts/BaseLayout';

const deals = [
  {
    title: 'roborock F25 GT Wet/Dry Vacuum',
    category: 'Smart Home',
    priceOld: 329,
    priceNew: 204,
    currency: '$',
    asin: 'B0DPHT4KB1',
    link: 'https://www.amazon.de/dp/B0DPHT4KB1?th=1&linkCode=ll2&tag=balu17051-21&linkId=af036d93ac55964a78dadadb6d997b73&ref_=as_li_ss_tl',
    image: 'https://m.media-amazon.com/images/I/51e70-aZRJL._AC_SX569_.jpg',
    hot: true,
  },
  {
    title: 'Echo Dot (5th Gen) Smart Speaker',
    category: 'Smart Home',
    priceOld: 59,
    priceNew: 33,
    currency: '$',
    asin: 'B09BDKJY6Q',
    link: 'https://www.amazon.de/dp/B09BDKJY6Q?tag=balu17051-21',
    image: 'https://m.media-amazon.com/images/I/51jONI3qKmL._AC_SX569_.jpg',
    hot: true,
  },
  {
    title: 'Fire HD 10 Tablet (32GB)',
    category: 'Tablets',
    priceOld: 149,
    priceNew: 89,
    currency: '$',
    asin: 'B08N5WRWNW',
    link: 'https://www.amazon.de/dp/B08N5WRWNW?tag=balu17051-21',
    image: 'https://m.media-amazon.com/images/I/51-phS739BL._AC_SX569_.jpg',
    hot: false,
  },
  {
    title: 'Samsung 980 PRO 1TB SSD',
    category: 'PC & Zubehör',
    priceOld: 179,
    priceNew: 114,
    currency: '$',
    asin: 'B08G73NKW4',
    link: 'https://www.amazon.de/dp/B08G73NKW4?tag=balu17051-21',
    image: 'https://m.media-amazon.com/images/I/51wCsc4U2dL._AC_SX569_.jpg',
    hot: false,
  },
];

const hotDeals = deals.filter(d => d.hot);
const normalDeals = deals.filter(d => !d.hot);
const discount = (newP: number, oldP: number) => Math.round((1 - newP / oldP) * 100);
---

<BaseLayout title="Angebote" description="Amazon-Deals im MyDealz-Stil: Top Deals, Preis und direkte Kauf-Links.">
  <div class="max-w-5xl mx-auto">
    <section class="py-8 sm:py-10">
      <h1 class="text-3xl sm:text-4xl font-extrabold text-white mb-2">Angebote</h1>
      <p class="text-gray-400 text-base sm:text-lg mb-6">
        Handverlesene Amazon-Rabatte — kompakt wie MyDealz.
      </p>
    </section>

    {hotDeals.length > 0 && (
      <section class="mb-10">
        <h2 class="text-xl font-extrabold text-white mb-4 flex items-center gap-2">
          🔥 Top Deals
        </h2>
        <div class="space-y-3">
          {hotDeals.map((deal) => (
            <a
              href={deal.link}
              target="_blank"
              rel="noopener sponsored"
              class="flex items-center gap-4 rounded-xl border border-orange-500/30 bg-orange-500/5 p-4 hover:border-orange-400/60 transition-colors"
            >
              <div class="hidden sm:block w-16 h-16 rounded-lg overflow-hidden bg-gray-900 border border-gray-800 shrink-0">
                <img src={deal.image} alt={deal.title} class="h-full w-full object-cover" loading="lazy" />
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-xs font-semibold uppercase tracking-wider rounded bg-orange-500/15 text-orange-300 border border-orange-500/30 px-2 py-0.5">
                    {deal.category}
                  </span>
                  <span class="text-xs font-bold text-orange-300">🔥 Top Deal</span>
                </div>
                <h3 class="text-base font-bold text-white truncate">
                  {deal.title}
                </h3>
              </div>
              <div class="text-right shrink-0">
                <div class="text-xl font-extrabold text-white">
                  {deal.currency}{deal.priceNew}
                </div>
                <div class="text-xs text-gray-500 line-through">{deal.currency}{deal.priceOld}</div>
                <div class="text-sm font-bold text-emerald-400">
                  -{discount(deal.priceNew, deal.priceOld)}%
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="mb-14">
      <h2 class="text-xl font-extrabold text-white mb-4">Alle Deals</h2>
      <div class="space-y-2">
        {normalDeals.map((deal) => (
          <a
            href={deal.link}
            target="_blank"
            rel="noopener sponsored"
            class="flex items-center gap-4 rounded-xl border border-gray-800 bg-gray-900/40 p-4 hover:border-primary/50 transition-colors"
          >
            <div class="hidden sm:block w-16 h-16 rounded-lg overflow-hidden bg-gray-900 border border-gray-800 shrink-0">
              <img src={deal.image} alt={deal.title} class="h-full w-full object-cover" loading="lazy" />
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs font-semibold uppercase tracking-wider rounded bg-primary/15 text-primary border border-primary/25 px-2 py-0.5">
                  {deal.category}
                </span>
              </div>
              <h3 class="text-base font-bold text-white truncate">
                {deal.title}
              </h3>
            </div>
            <div class="text-right shrink-0">
              <div class="text-xl font-extrabold text-white">
                {deal.currency}{deal.priceNew}
              </div>
              <div class="text-xs text-gray-500 line-through">{deal.currency}{deal.priceOld}</div>
              <div class="text-sm font-bold text-emerald-400">
                -{discount(deal.priceNew, deal.priceOld)}%
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="mb-14">
      <div class="p-4 rounded-lg bg-primary/10 border border-primary/20">
        <p class="text-sm text-gray-300 m-0">
          <strong class="text-primary">Hinweis:</strong> Affiliate-Links. Wenn du darüber kaufst, erhalten wir eine kleine Provision — für dich entstehen keine zusätzlichen Kosten.
        </p>
      </div>
    </section>
  </div>
</BaseLayout>
