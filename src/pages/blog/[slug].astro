---
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const allPosts = import.meta.glob('../../blog/*.md', { eager: true });
  const posts = Object.entries(allPosts).map(([path, post]: [string, any]) => ({
    slug: path.split('/').pop()?.replace('.md', ''),
    ...post.frontmatter,
  }));
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

// We need to dynamically load the content
const allPosts = import.meta.glob('../../blog/*.md', { eager: true });
const postKey = Object.keys(allPosts).find(k => k.includes(post.slug));
const postModule = postKey ? allPosts[postKey] : null;
const Content = postModule?.default || null;

// Affiliate-CTA based on tags/context
const affiliateCTA = getAffiliateCTA(post.tags || [], post.slug);

function getAffiliateCTA(tags: string[], slug: string) {
  const tagStr = tags.join(' ').toLowerCase();
  
  if (tagStr.includes('vpn') || slug.includes('vpn')) {
    
    return {
      title: '🔐 Schütz dein Internet mit einem VPN',
      description: 'Einer der schnellsten & günstigsten VPNs — getestet und empfohlen.',
      buttonText: '→ Surfshark sichern (bis 82% Rabatt)',
      url: 'https://surfshark.de/go/techpulse',
      badge: 'Deal',
    };
  }
  if (tagStr.includes('honeygain') || slug.includes('honeygain') || tagStr.includes('passives einkommen')) {
    return {
      title: '🍯 Passiv Geld verdienen während du schläfst',
      description: 'Honeygain zahlt dich für ungenutzte Internetbandbreite — komplett passiv.',
      buttonText: '→ Kostenlos starten + $5 Bonus',
      url: 'https://r.honeygain.me/STEHM0F453',
      badge: 'Empfehlung',
    };
  }
  if (tagStr.includes('domain') || slug.includes('domain')) {
    return {
      title: '🌐 Günstige Domains sichern',
      description: 'Namecheap — .com ab $5.88/Jahr inkl. Whois Privacy kostenlos.',
      buttonText: '→ Domains checken',
      url: 'https://namecheap.pxf.io/techpulse',
      badge: 'Deal',
    };
  }
  if (tagStr.includes('hetzner') || slug.includes('hetzner') || tagStr.includes('server') || tagStr.includes('homelab') || tagStr.includes('vps')) {
    return {
      title: '🖥️ Eigenen Server aufbauen?',
      description: 'Hetzner — Deutscher Hoster, DSGVO-konform, €20 Startguthaben für Neukunden.',
      buttonText: '→ €20 Guthaben sichern',
      url: 'https://www.hetzner.com?ref=TECHPULSE',
      badge: '€20 Bonus',
    };
  }
  if (tagStr.includes('contabo') || slug.includes('contabo')) {
    return {
      title: '💰 Günstiger VPS mit Traffic-Flat',
      description: 'Contabo — leistungsstarke Server ab €4.99/Monat mit 32 TB Traffic.',
      buttonText: '→ Contabo Angebote ansehen',
      url: 'https://contabo.com/en/vps/?affiliate=techpulse',
      badge: 'Günstig',
    };
  }
  if (slug.includes('earnapp')) {
    return {
      title: '💸 Bandbreite teilen, Geld verdienen',
      description: 'EarnApp — wie Honeygain, direkt in dein PayPal-Konto. Komplett passiv.',
      buttonText: '→ EarnApp kostenlos starten',
      url: 'https://earnapp.com/i/l9KWY9dJ',
      badge: 'Referral',
    };
  }
  
  // Default: Amazon Store
  return {
    title: '🛒 Meine Amazon Empfehlungen',
    description: 'Handverlesene Tech-Produkte — mit deinem Kauf unterstützt du TechPulse kostenlos.',
    buttonText: '→ Amazon Storefront besuchen',
    url: 'https://amzn.to/4eRHaXc',
    badge: 'Empfehlung',
  };
}
---

<BaseLayout title={post.title}>
  <article class="max-w-3xl mx-auto">
    <header class="mb-10">
      <div class="flex flex-wrap gap-2 mb-4">
        {(post.tags || []).map((tag) => (
          <span class="px-3 py-1 text-xs font-medium rounded-full bg-primary/20 text-primary border border-primary/30">
            {tag}
          </span>
        ))}
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-white mb-3 leading-tight">{post.title}</h1>
      <time datetime={post.date} class="text-gray-500 text-sm">
        {new Date(post.date).toLocaleDateString('de-DE', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </header>

    <div class="prose prose-invert prose-lg max-w-none
      prose-headings:text-white prose-a:text-primary prose-a:no-underline hover:prose-a:underline
      prose-code:text-accent prose-code:bg-gray-800/50 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
      prose-pre:bg-gray-900 prose-pre:border prose-pre:border-gray-800
      prose-blockquote:border-primary prose-blockquote:text-gray-400
      prose-img:rounded-xl">
      {Content && <Content />}
    </div>

    <!-- Prominent Affiliate CTA Box -->
    <div class="mt-12 rounded-2xl border-2 border-primary/50 bg-gradient-to-br from-primary/10 via-gray-900 to-accent/10 p-6 sm:p-8 relative overflow-hidden">
      <div class="absolute top-3 right-3 px-3 py-1 text-xs font-bold rounded-full bg-primary text-white animate-pulse">
        {affiliateCTA.badge}
      </div>
      <h3 class="text-xl sm:text-2xl font-bold text-white mb-2">{affiliateCTA.title}</h3>
      <p class="text-gray-400 mb-5">{affiliateCTA.description}</p>
      <a
        href={affiliateCTA.url}
        target="_blank"
        rel="noopener sponsored"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-primary hover:bg-primary/80 text-white font-bold text-base transition-all duration-300 hover:scale-105 shadow-lg shadow-primary/25"
      >
        {affiliateCTA.buttonText}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      </a>
      <p class="text-gray-600 text-xs mt-3">Partner-Link · Keine zusätzlichen Kosten für dich</p>
    </div>

    <!-- Back link -->
    <div class="mt-8 pt-6 border-t border-gray-800">
      <a href={`${import.meta.env.BASE_URL}blog/`} class="text-primary hover:text-accent transition-colors font-medium">
        ← Zurück zum Blog
      </a>
    </div>
  </article>
</BaseLayout>
