---
import BaseLayout from '../layouts/BaseLayout';

const deal = {
  title: 'roborock F25 GT Wet/Dry Vacuum',
  category: 'Smart Home',
  priceOld: 329,
  priceNew: 204,
  currency: '$',
  asin: 'B0DPHT4KB1',
  link: 'https://www.amazon.de/dp/B0DPHT4KB1?th=1&linkCode=ll2&tag=balu17051-21&linkId=af036d93ac55964a78dadadb6d997b73&ref_=as_li_ss_tl',
  image: 'https://m.media-amazon.com/images/I/51e70-aZRJL._AC_SX569_.jpg',
  tags: ['Vacuum', 'Mop', 'Self-Cleaning']
};
---

<BaseLayout title="Amazon Deal" description={`${deal.title} – jetzt günstiger: ${deal.currency}${deal.priceNew} statt ${deal.currency}${deal.priceOld}`}>
  <div class="max-w-3xl mx-auto">
    <section class="py-10 sm:py-14">
      <div class="flex items-center gap-3 mb-4">
        <span class="px-3 py-1 text-xs font-semibold uppercase tracking-wider rounded bg-primary/15 text-primary border border-primary/25">
          {deal.category}
        </span>
        <span class="px-3 py-1 text-xs font-semibold uppercase tracking-wider rounded bg-emerald-400/10 text-emerald-300 border border-emerald-400/20">
          -{Math.round((1 - deal.priceNew / deal.priceOld) * 100)}%
        </span>
      </div>

      <div class="rounded-2xl border border-gray-800 bg-gradient-to-br from-gray-900 to-gray-900/60 overflow-hidden">
        <div class="aspect-video bg-gray-950">
          <img src={deal.image} alt={deal.title} class="h-full w-full object-cover" loading="eager" />
        </div>
        <div class="p-6 sm:p-8">
          <h1 class="text-2xl sm:text-3xl font-extrabold text-white mb-3">
            {deal.title}
          </h1>
          <div class="flex items-end gap-2 mb-5">
            <span class="text-3xl font-extrabold text-white">{deal.currency}${deal.priceNew}</span>
            <span class="text-sm text-gray-500 line-through mb-1">{deal.currency}${deal.priceOld}</span>
          </div>
          <div class="flex flex-wrap gap-2 mb-6">
            {deal.tags.map((tag) => (
              <span class="px-2 py-1 text-xs font-semibold uppercase tracking-wider rounded bg-gray-800 text-gray-300">
                {tag}
              </span>
            ))}
          </div>
          <a
            href={deal.link}
            target="_blank"
            rel="noopener sponsored"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl bg-primary hover:bg-primary/80 text-white font-bold transition-all duration-300 hover:scale-[1.02]"
          >
            Jetzt bei Amazon kaufen
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <section class="mb-14">
      <div class="p-4 rounded-lg bg-primary/10 border border-primary/20">
        <p class="text-sm text-gray-300 m-0">
          <strong class="text-primary">Hinweis:</strong> Affiliate-Link. Wenn du darüber kaufst, erhalten wir eine kleine Provision — für dich entstehen keine zusätzlichen Kosten.
        </p>
      </div>
    </section>
  </div>
</BaseLayout>
